# Mouse — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ── Locale / Encoding ───────────────────────
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8

# ── Python ──────────────────────────────────
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
# PYTHONPATH=Source/Python

# ── Rust ────────────────────────────────────
RUST_LOG=info
RUST_BACKTRACE=1
# RUSTFLAGS=-C target-cpu=native

# ── GPU / Vision ────────────────────────────
# APPLE_GPU_ENABLED=true
# NVIDIA_GPU_ENABLED=true
# CUDA_VISIBLE_DEVICES=0

# ── Screen Capture ──────────────────────────
# SCREEN_CAPTURE_API=auto    # auto, cgdisplay, dxgi, metal
# SCREEN_CAPTURE_FPS=60
# SCREEN_CAPTURE_RESOLUTION=1920x1080

# ── Cursor ──────────────────────────────────
# CURSOR_SMOOTHING=true
# CURSOR_SENSITIVITY=1.0
# CURSOR_ACCELERATION=false

# ── Logging ─────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=Data/mouse.log
# LOG_FORMAT=json

# ── Development ─────────────────────────────
DEBUG=false
# DEV_MODE=true
# PROFILE_MODE=false

# ── Python Environment ─────────────────────
# Activate with: mamba activate mouse
# Or prefix commands: mamba run -n mouse <cmd>
# CONDA_ENV=mouse
