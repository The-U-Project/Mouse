# Mouse — EditorConfig
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{rs,rs.in}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json,jsonc}]
indent_style = space
indent_size = 2

[*.{cpp,cxx,cc,c,h,hpp,hxx,hh}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{cu,cuh}]
indent_style = space
indent_size = 4

[*.{asm,s,S}]
indent_style = space
indent_size = 8

[*.{phtml,php}]
indent_style = space
indent_size = 4

[*.{md,mdx,txt,rst}]
indent_style = space
indent_size = 2
max_line_length = 80

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{toml,cfg,ini}]
indent_style = space
indent_size = 4

[Makefile,*.mk]
indent_style = tab
indent_size = 4

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

[*.bat]
end_of_line = crlf
